# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set the provider you want to use: "openai", "anthropic", or "gemini"
LLM_PROVIDER=gemini

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini (used when LLM_PROVIDER=gemini)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Embeddings ────────────────────────────────────────────────────────────────
# Which embedding model to use: openai, gemini, or huggingface
EMBEDDING_PROVIDER=gemini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Web Search (Phase 4) ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── LangSmith Observability (Phase 7) ────────────────────────────────────────
# Set to "true" to enable tracing; leave unset or "false" to disable
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=insightagent

# ── FastAPI ───────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
